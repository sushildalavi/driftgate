{
  "title": "DRIFTGATE Runtime Contract Registry",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {"type": "timeseries", "title": "Drift Count by Severity", "targets": [{"expr": "sum by (severity) (drift_count_total)"}], "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}},
    {"type": "timeseries", "title": "Compatibility Classification Totals", "targets": [{"expr": "sum by (classification) (compatibility_classification_total)"}], "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}},
    {"type": "timeseries", "title": "p95 Drift Detection Latency", "targets": [{"expr": "histogram_quantile(0.95, sum(rate(drift_detection_latency_seconds_bucket[5m])) by (le))"}], "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}},
    {"type": "timeseries", "title": "Advisory Lock Wait", "targets": [{"expr": "histogram_quantile(0.95, sum(rate(advisory_lock_wait_seconds_bucket[5m])) by (le))"}], "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}},
    {"type": "timeseries", "title": "Webhook Failure Rate", "targets": [{"expr": "rate(webhook_delivery_failures_total[5m])"}], "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16}},
    {"type": "stat", "title": "DLQ Size", "targets": [{"expr": "dlq_size"}], "gridPos": {"h": 8, "w": 6, "x": 12, "y": 16}},
    {"type": "timeseries", "title": "Kafka Publish Failures", "targets": [{"expr": "rate(kafka_publish_failures_total[5m])"}], "gridPos": {"h": 8, "w": 6, "x": 18, "y": 16}}
  ]
}
