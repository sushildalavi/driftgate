# Database
DATABASE_URL=postgresql+asyncpg://driftgate:dev@localhost:5432/driftgate
DATABASE_URL_SYNC=postgresql://driftgate:dev@localhost:5432/driftgate

# Auth
ADMIN_SECRET=dev-secret

# LLM (optional - template fallback used when unset)
ANTHROPIC_API_KEY=
LLM_MODEL=claude-haiku-4-5-20251001

# CORS
FRONTEND_ORIGINS=http://localhost:5174

# Registry
REGISTRY_PATH=/app/config/apis.yaml

# Tunables
FETCH_TIMEOUT_SEC=10
RAW_BODY_MAX_BYTES=262144
RAW_RETENTION_PER_ENDPOINT=10

# Frontend (build-time)
VITE_API_BASE_URL=http://localhost:8080
